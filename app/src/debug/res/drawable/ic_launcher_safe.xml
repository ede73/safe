            </gradient>
        </aapt:attr>
    </path>

    <!-- Key shaft left-edge vertical highlight -->
    <path
        android:strokeWidth="0.5"
        android:strokeColor="#FF80AB"
        android:pathData="M31.0,22.5 V34.5" />

    <!-- Key head top-left curved highlight -->
    <path
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:strokeColor="#FFFFFF"
