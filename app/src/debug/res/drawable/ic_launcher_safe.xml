                android:type="linear">
                <item android:offset="0.0" android:color="#78909C" />
                <item android:offset="0.3" android:color="#B0BEC5" />
                <item android:offset="0.6" android:color="#ECEFF1" />
                <item android:offset="0.8" android:color="#90CAF9" />
                <item android:offset="1.0" android:color="#64B5F6" />
            </gradient>
        </aapt:attr>
    </path>

