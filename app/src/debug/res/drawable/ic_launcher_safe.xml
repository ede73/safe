                <item android:offset="0.2" android:color="#F06292" />
                <item android:offset="0.5" android:color="#EC407A" />
                <item android:offset="0.8" android:color="#D81B60" />
                <item android:offset="1.0" android:color="#880E4F" />
            </gradient>
